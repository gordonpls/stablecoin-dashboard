# Database
DATABASE_URL=sqlite:///./stablecoin.db

# API Keys (free tiers only unless approved)
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
THEGRAPH_API_KEY=

# Provider budgets (monthly USD limits — 0 = unlimited free tier)
BUDGET_COINGECKO=0
BUDGET_ETHERSCAN=0
BUDGET_THEGRAPH=0

# Cache settings
CACHE_TTL_PRICES=60          # seconds — peg prices
CACHE_TTL_SUPPLY=3600        # seconds — supply data
CACHE_TTL_RESERVES=86400     # seconds — reserve reports

# Rate limits (requests per minute)
RATE_LIMIT_DEFILLAMA=30
RATE_LIMIT_COINGECKO=10
RATE_LIMIT_EXCHANGES=60

# Logging
LOG_LEVEL=INFO
LOG_API_USAGE=true
