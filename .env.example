# Database — any SQLAlchemy URL. Defaults to the committed SQLite file.
DATABASE_URL=sqlite:///./stablecoin.db

# Dashboard — password gating the write controls (watchlist / alert editors).
# Set a strong value in your deployment; do not ship the default.
DASHBOARD_PASSWORD=

# API keys — free tiers only unless approved. Used by the post-MVP ingestion
# modules (ingestion/coingecko.py, etherscan.py, thegraph.py). The live
# pipelines (DefiLlama + exchanges) require no key.
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
THEGRAPH_API_KEY=

# Per-provider daily CALL caps, enforced by core/budget.py over a rolling 24h
# window. 0 = unlimited (the default for every free-tier provider).
BUDGET_DEFILLAMA=0
BUDGET_BINANCE=0
BUDGET_COINBASE=0

# Per-provider rate limits (requests/minute), enforced by ingestion/_base.py.
RATE_LIMIT_DEFILLAMA=30
RATE_LIMIT_COINGECKO=10
RATE_LIMIT_EXCHANGES=60

# Optional readiness gate (services/readiness.py): comma-separated env-var names
# that MUST be set, or the deployment is reported as misconfigured.
# REQUIRED_ENV_VARS=

# Note: cache TTLs are configured in code (core/cache.py defaults + per-call
# ttl= in the ingestion clients), not via environment variables.
